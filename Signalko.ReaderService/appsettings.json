{
    "ConnectionStrings": {
        "DefaultConnection": "Server=localhost;Port=3306;Database=signalko;User=root;Password=;TreatTinyAsBoolean=true"
    },

    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.Hosting.Lifetime": "Information"
        }
    },
    "ReaderSupervisor": {
        "IntervalSeconds": 15,
        "FailThreshold": 3,
        "OkThreshold": 2,
        "PingAttempts": 3,
        "TcpPorts": [ 5084, 80, 443 ],
        "Fx7500": {
            "EnableWake": true,
            "UseHttps": false,
            "WakePath": "/goform/reboot",
            "Username": "root",
            "Password": ""
        }
    }
}
